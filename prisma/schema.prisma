generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Movie {
  id         Int      @id @default(autoincrement())
  title      String
  year       Int
  rating     String
  categories String
  starRating Float
  posterPath String
  createdAt  DateTime @default(now())
}
